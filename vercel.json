{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://exam-platform-6vs7.onrender.com/api/$1"
    }
  ],
  "builds": [
    {
      "src": "frontend/index.html",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "frontend/dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "frontend/$1"
    }
  ]
}
